  "keyFeatures": [
    "Cross-chain asset transfers with lock-and-mint mechanism",
    "Arbitrary data messaging between blockchains",
    "Decentralized oracle network for transaction validation",
    "Call proxy for executing cross-chain smart contract calls",
    "Flexible fee structure with discounts",
    "Support for native tokens and ERC-20 assets"
  ],
